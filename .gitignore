# Minimal ignore — everything else (CSVs, figures, .env variants, results) is
# intentionally committed and shared across machines.

# Python / OS junk only
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.DS_Store

# The active machine-specific symlink (the .env.laptop/.env.server templates
# ARE committed; the resolved symlink itself is not).
.env
