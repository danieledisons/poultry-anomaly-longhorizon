# Copy this file per machine, then symlink it to `.env`:
#   ln -sf .env.laptop .env      (laptop)
#   ln -sf .env.server .env      (server)
#
# Only PROJECT_ROOT is required. The others default to sensible sub-folders of
# PROJECT_ROOT (see config.py) — set them only if a folder lives elsewhere
# (e.g. raw video on an external drive or a server scratch disk).

PROJECT_ROOT=/absolute/path/to/poultry-anomaly-longhorizon

# Optional overrides (uncomment only if needed):
# DATA_DIR=/absolute/path/to/data
# RAW_DIR=/mnt/bigdisk/longhorizon/raw
# FEATURES_DIR=/absolute/path/to/features
# RESULTS_DIR=/absolute/path/to/results
# FIGURES_DIR=/absolute/path/to/figures
